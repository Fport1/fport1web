rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
      match /friends/{friendUid} {
        // Own list, or the friend writing/removing themselves (mutual operations)
        allow read, write: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == friendUid);
      }
    }

    match /usernames/{slug} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /presence/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Launcher sessions — public read (launcher reads before signing in)
    match /launcher_sessions/{code} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /friendRequests/{reqId} {
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      // Split read rules so Firestore can verify each from query constraints
      allow read: if request.auth != null && resource.data.fromUid == request.auth.uid;
      allow read: if request.auth != null && resource.data.toUid   == request.auth.uid;
      allow update: if request.auth != null && resource.data.toUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.fromUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.toUid   == request.auth.uid;
    }

    // Conversations (mensajes page)
    match /conversations/{cid} {
      allow read, update: if request.auth != null && request.auth.uid in resource.data.participantUids;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantUids;
      allow delete: if request.auth != null && request.auth.uid in resource.data.participantUids;
      match /messages/{msgId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.participantUids;
      }
    }

    // Chat invite links (personal link per user)
    match /chatLinks/{token} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Conversation share links (?v=token)
    match /convLinks/{token} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
    }

    // Avengers: Doomsday — lista de asistentes al estreno
    // CERRADA al público hasta la preventa Latam: solo @fport1 puede leer/escribir.
    // Al abrirla, restaurar: read para autenticados + create/update/delete del propio uid.
    match /doomsday_rsvps/{uid} {
      function isDoomsdayAdmin() {
        return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.usernameSlug == 'fport1';
      }
      allow read, write: if isDoomsdayAdmin();
    }

    match /chats/{chatId} {
      // get: allow reading non-existent docs (resource == null) so openChat can check existence
      allow get:    if request.auth != null && (resource == null || request.auth.uid in resource.data.members);
      allow list:   if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.members;
      match /messages/{msgId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }
    }
  }
}